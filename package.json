{
  "name": "quantum-pi-forge-fixed",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && npx eslint --max-warnings=0 .",
    "format": "prettier --write .",
    "deploy": "chmod +x scripts/deploy-quantum.sh && ./scripts/deploy-quantum.sh",
    "debug": "node scripts/debug-quantum.js",
    "quantum:init": "cp .env.example .env.local",
    "quantum:test": "npm run build && npm run start",
    "quantum:clean": "rm -rf .next node_modules/.cache",
    "quantum:full-deploy": "npm run quantum:clean && npm ci && npm run build && vercel --prod",
    "postbuild": "node postbuild.js",
    "analyze": "ANALYZE=true next build",
    "install:python": "pip install -r requirements.txt",
    "setup:tracing": "chmod +x setup-tracing.sh && ./setup-tracing.sh",
    "test:tracing": "python3 test-tracing.py",
    "trace:start": "ai-mlstudio.tracing.open",
    "guardian": "python deepseek_guardian.py",
    "nexus": "python ai_nexus_sync.py",
    "oracle": "python sovereign_economic_oracle.py",
    "quantum": "python quantum_resonance_field.py",
    "fastapi": "cd fastapi && python -m uvicorn main:app --reload",

    "eval:install": "pip install -r evaluation/requirements.txt",
    "eval:run": "python evaluation/run_evaluation.py --data evaluation/evaluation_dataset.jsonl --output evaluation_results",
    "eval:collect": "npx tsx evaluation/collect_responses.ts",

    "prune:deps": "npm prune && npm dedupe",

    "dev:fast": "cross-env NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS=\"--max-old-space-size=4096\" next dev --turbopack",
    "clean:all": "rimraf .next node_modules/.cache out && echo Cleaned caches",
    "startup:check": "bash scripts/startup-check.sh",

    "deploy:frontend": "chmod +x scripts/deploy-frontend.sh && ./scripts/deploy-frontend.sh",
    "deploy:backend": "chmod +x scripts/deploy-backend.sh && ./scripts/deploy-backend.sh",
    "deploy:all": "npm run deploy:frontend && npm run deploy:backend",
    "health:check": "bash scripts/health-check.sh",
    "maintenance:daily": "bash scripts/daily-maintenance.sh",
    "rollback:emergency": "bash scripts/rollback.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.12",
    "@ai-sdk/xai": "^3.0.27",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-zone": "^2.4.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.210.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.210.0",
    "@opentelemetry/instrumentation": "^0.210.0",
    "@opentelemetry/instrumentation-document-load": "^0.55.0",
    "@opentelemetry/instrumentation-fetch": "^0.210.0",
    "@opentelemetry/instrumentation-http": "^0.210.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.54.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.210.0",
    "@opentelemetry/resources": "^2.4.0",
    "@opentelemetry/sdk-trace-node": "^2.4.0",
    "@opentelemetry/sdk-trace-web": "^2.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ai": "^6.0.42",
    "autoprefixer": "^10.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "embla-carousel-react": "^9.0.0-rc01",
    "ethers": "^6.7.0",
    "firebase": "^12.8.0",
    "framer-motion": "^10.0.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.4.1",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.3.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.0.0",
    "@tailwindcss/forms": "^0.5.0",
    "@tailwindcss/typography": "^0.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.7",
    "tsx": "^3.12.7",
    "typescript": "^5.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "git add"
    ],
    "*.{json,md,css,scss,html}": [
      "prettier --write",
      "git add"
    ]
  },
  "prepare": "husky install",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
