TWITTER_API_KEY=  # Optional
TWITTER_API_SECRET=  # Optional
TWITTER_ACCESS_TOKEN=  # Optional
TWITTER_TOKEN_SECRET=  # Optional

# 9. LOGGING & DIAGNOSTICS
LOG_LEVEL=info  # debug, info, warn, error
LOG_FILE=./logs/launch.log
ENABLE_TRACE=true

# 10. EMERGENCY CONTROLS
# Pause/resume operations
LAUNCH_PAUSED=false
EMERGENCY_DRAIN_ADDRESS=0x3e81132dcA223a7d8D58ea769F6c91d4B64B73d7  # Set to deployer by default
