# Production Environment Variables
# NEVER commit actual values to git!

# Application
ENVIRONMENT=production
PRODUCTION_DOMAIN=quantumpiforge.com

# CORS Configuration
ALLOWED_ORIGINS=https://quantumpiforge.com,https://www.quantumpiforge.com,https://api.quantumpiforge.com

# Security
SECRET_KEY=your-production-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://user:password@host:port/database

# Pi Network
PI_NETWORK_API_KEY=your-pi-api-key
PI_NETWORK_WALLET_SECRET=your-wallet-secret

# Redis
REDIS_URL=redis://redis:6379/0

# Monitoring
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=WARNING

# Email/SMTP (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# External APIs
COINGECKO_API_KEY=optional-coin-gecko-key
ETHERSCAN_API_KEY=optional-etherscan-key