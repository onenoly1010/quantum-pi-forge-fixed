# Quantum Pi Forge Production Environment Variables
# DO NOT COMMIT THIS FILE - Use GitHub Secrets instead

# ===========================================
# BLOCKCHAIN / WEB3
# ===========================================
# Sponsor wallet for gasless transactions (GitHub Secret)
SPONSOR_PRIVATE_KEY=${{ secrets.SPONSOR_PRIVATE_KEY }}

# Polygon network RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# OINIO Token Contract Address
OINIO_TOKEN_ADDRESS=0x07f43E5B1A8a0928B364E40d5885f81A543B05C7

# For Hardhat deployments (GitHub Secret)
DEPLOYER_PRIVATE_KEY=${{ secrets.DEPLOYER_PRIVATE_KEY }}

# 0G Network RPC
ZERO_G_RPC_URL=https://rpc.0g.ai

# ===========================================
# AI / OPENAI
# ===========================================
# Direct OpenAI API Key (GitHub Secret)
OPENAI_API_KEY=${{ secrets.OPENAI_API_KEY }}

# Vercel AI Gateway (optional - for caching/analytics)
AI_GATEWAY_API_KEY=${{ secrets.AI_GATEWAY_API_KEY }}
AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1

# ===========================================
# NEXT.JS
# ===========================================
NEXT_PUBLIC_APP_URL=https://quantumpiforge.com

# ===========================================
# AUTHENTICATION
# ===========================================
# JWT Secret (GitHub Secret)
JWT_SECRET=${{ secrets.JWT_SECRET }}

# NextAuth Configuration
NEXTAUTH_URL=https://quantumpiforge.com
NEXTAUTH_SECRET=${{ secrets.NEXTAUTH_SECRET }}

# GitHub OAuth (GitHub Secret)
GITHUB_CLIENT_ID=${{ secrets.GITHUB_CLIENT_ID }}
GITHUB_CLIENT_SECRET=${{ secrets.GITHUB_CLIENT_SECRET }}

# Pi Network API Key (GitHub Secret)
PI_API_KEY=${{ secrets.PI_API_KEY }}

# ===========================================
# DATABASE
# ===========================================
# MongoDB Connection (GitHub Secret)
MONGODB_URI=${{ secrets.MONGODB_URI }}
DATABASE_NAME=quantumpiforge_prod

# ===========================================
# MONITORING
# ===========================================
# Sentry DSN for error tracking (GitHub Secret)
SENTRY_DSN=${{ secrets.SENTRY_DSN }}

# ===========================================
# DEPLOYMENT
# ===========================================
NODE_ENV=production
VERCEL_ENV=production