# Quantum Pi Forge API Environment Variables

# Server Configuration
PORT=3001
HOST=localhost
NODE_ENV=development

# Security
JWT_SECRET=your_super_secure_jwt_secret_here
JWT_EXPIRES_IN=24h
SESSION_TIMEOUT=86400000

# Database
DATABASE_URL=mongodb://localhost:27017/quantumpiforge
DATABASE_NAME=quantumpiforge
DB_MAX_POOL_SIZE=10
DB_SERVER_SELECTION_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000

# Pi Network
PI_API_KEY=your_pi_api_key
PI_APP_ID=your_pi_app_id
PI_SANDBOX=true
PI_WEBHOOK_SECRET=your_webhook_secret

# Blockchain - Polygon
POLYGON_RPC_URL=https://polygon-rpc.com/
SOUL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
HYBRID_NFT_ADDRESS=0x0000000000000000000000000000000000000000
EVOLUTION_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
METADATA_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Pi Testnet (if needed)
PI_TESTNET_RPC_URL=https://your_pi_testnet_rpc_url

# External Services
IPFS_API_KEY=your_ipfs_api_key
IPFS_SECRET_KEY=your_ipfs_secret_key
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
REDIS_URL=redis://localhost:6379
REDIS_TTL=86400

# Oracle Configuration
ORACLE_ENABLED=true
ORACLE_CACHE_TIMEOUT=300000
ORACLE_MAX_READINGS_PER_HOUR=100

# iNFT Configuration
INFT_MAX_EVOLUTION_LEVEL=10
INFT_EVOLUTION_COOLDOWN=86400000
INFT_METADATA_CACHE_TIMEOUT=3600000

# Logging
LOG_LEVEL=info
LOG_CONSOLE=true
LOG_FILE=false
LOG_DIR=./logs
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Feature Flags
ENABLE_EVOLUTION=true
ENABLE_MINTING=true
ENABLE_MARKETPLACE=false
ENABLE_ANALYTICS=true

# Monitoring
MONITORING_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30000